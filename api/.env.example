# SetupSO API — environment variables
# Copy this file to .env and fill in the values.

# PostgreSQL connection string
DATABASE_URL=postgres://setupso:setupso123@localhost:5432/setupso

# JWT secret — CHANGE THIS in production (use a long random string)
JWT_SECRET=change-me-in-production-use-random-string

# JWT token lifetime (e.g. 8h, 24h, 7d)
JWT_EXPIRES_IN=8h

# API port
PORT=3001

# CORS allowed origin (use the frontend URL in production)
# Set to * for local dev; in production set to your actual domain.
CORS_ORIGIN=*
