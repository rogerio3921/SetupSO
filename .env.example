# Variáveis de ambiente — SetupSO MVP online
# Copie este arquivo para .env e preencha os valores

# Porta do servidor
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://setupso:senha_segura@localhost:5432/setupso

# JWT — troque por uma string aleatória longa (ex: openssl rand -hex 64)
JWT_SECRET=troque_por_segredo_aleatorio_longo_aqui
JWT_EXPIRES_IN=8h

# Admin padrão criado na primeira execução (caso não existam usuários)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# Ambiente: development | production
NODE_ENV=development
