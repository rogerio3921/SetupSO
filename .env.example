# SetupSO — Backend — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env real.

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- JWT ---
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_STRING_ALEATORIA_LONGA_E_SEGURA
JWT_EXPIRES_IN=8h

# --- Banco de dados ---
# Para SQLite, forneça o caminho do arquivo. Padrão: ./server/db/setupso.sqlite
DB_PATH=./server/db/setupso.sqlite

# --- CORS ---
# Origens permitidas, separadas por vírgula. Em produção, use apenas o domínio real.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# --- Segurança ---
# Número de rounds do bcrypt (>=12 recomendado em produção)
BCRYPT_ROUNDS=12

# --- Primeiro usuário administrador (criado automaticamente na primeira inicialização) ---
ADMIN_USERNAME=admin
# ATENÇÃO: Altere esta senha imediatamente após o primeiro login.
ADMIN_PASSWORD=SetupSO@2026!
ADMIN_DISPLAY_NAME=Administrador
