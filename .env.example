# SetupSO — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Node.js ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Connection string used by the API service.
DATABASE_URL=postgresql://setupso:changeme@localhost:5432/setupso

# Individual credentials used by the postgres container (docker-compose).
POSTGRES_DB=setupso
POSTGRES_USER=setupso
POSTGRES_PASSWORD=changeme

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-256-bit-secret-never-share-this

# JWT token lifetime (e.g. 8h, 24h, 7d)
JWT_EXPIRES_IN=8h

# bcrypt cost factor — minimum 12 for production
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example for production: https://setupso.hospital.com
# Example for local dev:  http://localhost, http://127.0.0.1:5500
CORS_ORIGIN=http://localhost

# ── Optional / Future ─────────────────────────────────────────────────────────
# Uncomment when needed.

# Log level (debug | info | warn | error)
# LOG_LEVEL=info

# Session secret (if using cookie-based sessions instead of JWT)
# SESSION_SECRET=replace-with-another-random-secret

# SMTP settings (for password-reset emails — future feature)
# SMTP_HOST=smtp.hospital.com
# SMTP_PORT=587
# SMTP_USER=noreply@hospital.com
# SMTP_PASS=smtp-password
# SMTP_FROM="SetupSO <noreply@hospital.com>"
