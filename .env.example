# Variáveis de ambiente — SetupSO API
# Copie este arquivo para .env e preencha os valores antes de rodar.
# NUNCA commite o .env com valores reais no repositório.

# ─── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Banco de dados ────────────────────────────────────────────────────────────
# Para desenvolvimento local com SQLite:
DB_CLIENT=sqlite3
SQLITE_PATH=./api/dev.db

# Para produção com PostgreSQL (substitua DB_CLIENT e descomente DATABASE_URL):
# DB_CLIENT=pg
# DATABASE_URL=postgres://setupso_user:TROQUE_A_SENHA@db:5432/setupso_db

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Gere um segredo forte: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE_ESTE_SEGREDO_POR_UMA_STRING_ALEATORIA_LONGA
JWT_EXPIRES_IN=8h

# ─── Segurança ─────────────────────────────────────────────────────────────────
# Custo do bcrypt (mínimo 12 em produção)
BCRYPT_ROUNDS=12

# Origem permitida pelo CORS (URL do frontend)
# Em desenvolvimento pode usar * ou http://localhost:5500
CORS_ORIGIN=http://localhost:5500

# ─── Admin inicial (seed) ──────────────────────────────────────────────────────
# Usado apenas na criação inicial do banco. Altere a senha imediatamente após o primeiro login.
ADMIN_USERNAME=admin
ADMIN_NAME=Administrador
ADMIN_PASSWORD=TROQUE_ANTES_DE_USAR_EM_PRODUCAO
