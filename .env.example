# Copy this file to .env and fill in the values
# cp .env.example .env

# Postgres connection string
DATABASE_URL=postgres://setupso:setupso_dev@localhost:5432/setupso

# Set to "true" if Postgres requires SSL (e.g. cloud providers like Supabase/Heroku)
DATABASE_SSL=false

# JWT signing secret — CHANGE THIS in production!
JWT_SECRET=dev-jwt-secret-change-in-production

# API port
PORT=3000
