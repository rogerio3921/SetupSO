{
  "name": "setupso",
  "version": "0.2.0",
  "description": "SetupSO — Surgical-Center Setup Coordination Tool",
  "private": true,
  "scripts": {
    "dev": "docker compose up",
    "dev:down": "docker compose down",
    "dev:logs": "docker compose logs -f",
    "dev:db": "docker compose up -d postgres",
    "dev:api": "cd api && node server.js",
    "dev:frontend": "npx serve . -p 5500",
    "build": "docker compose build",
    "db:migrate": "docker compose exec api node db/migrate.js",
    "db:seed": "docker compose exec api node db/seed.js",
    "db:backup": "docker compose exec postgres pg_dump -U $POSTGRES_USER $POSTGRES_DB > backup_$(date +%Y%m%d_%H%M%S).sql",
    "lint": "echo 'No linter configured yet'",
    "test": "echo 'No tests configured yet'"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "hospital",
    "surgical-center",
    "setup",
    "coordination",
    "mvp"
  ],
  "license": "UNLICENSED"
}
