{
  "default_rules": [
    {
      "id": "rule-cme-delay",
      "name": "Atraso CME (início conferência)",
      "type": "cme_delay",
      "level": "warn",
      "condition": { "minutes_after_fim_procedimento": 10 },
      "window_minutes": 10,
      "destinatarios": ["cme", "coordenacao", "enfermagem"]
    },
    {
      "id": "rule-cleaning-without-exit",
      "name": "Tentativa de limpeza sem saída do paciente",
      "type": "cleaning_without_exit_attempt",
      "level": "critical",
      "condition": {},
      "destinatarios": ["coordenacao", "enfermagem"]
    },
    {
      "id": "rule-cleaning-delay-from-exit",
      "name": "Atraso limpeza após saída",
      "type": "cleaning_delay_from_exit",
      "level": "warn",
      "condition": { "minutes_after_exit": 15 },
      "destinatarios": ["limpeza", "coordenacao"]
    },
    {
      "id": "rule-cme-duration-excess",
      "name": "Duração CME excedida",
      "type": "cme_duration_excess",
      "level": "warn",
      "condition": { "expected_minutes": 10, "factor": 1.5 },
      "destinatarios": ["cme", "coordenacao"]
    },
    {
      "id": "rule-turnover-high",
      "name": "Turnover alto",
      "type": "turnover_acima",
      "level": "warn",
      "condition": { "turnover_minutes": 30 },
      "destinatarios": ["coordenacao", "enfermagem"]
    }
  ]
}
